<article id="<%= post.layout %>-<%= post.slug %>" class="article article-type-<%= post.layout %>" itemscope itemprop="blogPost">
  <%if(post.noDate != "true"){%>
    <div class="article-meta">
      <%- partial('post/date', {class_name: 'article-date', date_format: null}) %>
    </div>
  <%}%>
  <div class="article-inner">
    <% if (theme.fancybox){ %>
      <input type="hidden" class="isFancy" />
    <% } %>
    <% if (post.link || post.title){ %>
      <header class="article-header">
        <%- partial('post/title', {class_name: 'article-title'}) %>
      </header>
      <% if (!index){ %>
      <div class="article-info article-info-post">
        <%- partial('post/category') %>
        <%- partial('post/tag') %>
        <div class="clearfix"></div>
      </div>
      <% } %>
    <% } %>

    <div class="article-entry" itemprop="articleBody">
        <% post.movies.forEach(function(movie){ %>
            <h2><%- movie.title %></h2>
            <div class="row">
                <div class="movie-image">
                    <img src="<%- movie.image %>" alt="<%- movie.title %>" />
                </div>
                <div class="movie-table">
                    <table style="float:right">
                        <tbody>
                            <tr>
                                <td style="width:20%">英文名字</td>
                                <td style="width:80%"><%- movie.eng_title %></td>
                            </tr>
                            <tr>
                                <td>上映时间</td>
                                <td><%- movie.release_date %></td>
                            </tr>
                            <tr>
                                <td>观影时间</td>
                                <td><%- movie.see_date %></td>
                            </tr>
                            <tr>
                                <td>观影地点版本</td>
                                <td><%- movie.location %> | <%- movie.version %></td>
                            </tr>
                            <tr>
                                <td>相关连接</td>
                                <td><a href="http://movie.douban.com/subject/<%- movie.douban_id%>/">豆瓣</a> | <a href="http://www.imdb.com/title/<%- movie.imdb_id%>/">IMDB</a></td>
                            </tr>
                            <tr>
                                <td>豆瓣评分</td>
                                <td><%- movie.douban_star %></td>
                            </tr>
                            <tr>
                                <td>短评</td>
                                <td><%- movie.comment %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        <% }) %>
    </div>

    <% if (index){ %>
    <div class="article-info article-info-index">
      <%if(post.top){%>
        <div class="article-pop-out tagcloud">
          <a class="">置顶</a>
        </div>
      <% } %>
      <%- partial('post/category') %>
      <%- partial('post/tag') %>
      <% if (index && (post.description || post.excerpt)){ %>
        <p class="article-more-link">
          <a <% if (!theme.excerpt_link){ %>class="hidden"<% } %> href="<%- url_for(post.path) %>#more"><%= theme.excerpt_link %> >></a>
        </p>
      <% } %>
      <div class="clearfix"></div>
    </div>
    <% } %>
  </div>
  <% if (!index){ %>
    <%- partial('post/nav') %>
  <% } %>
</article>
<% if (!index && post.toc != false && !is_page()){ %>
    <%- partial('_partial/toc') %>
<% } %>
<% if (!index && theme.share){ %>
<%- partial('post/share') %>
<% } %>
